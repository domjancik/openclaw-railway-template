{
  "name": "openclaw-railway",
  "version": "2.0.0",
  "private": true,
  "description": "OpenClaw on Railway — one-click deploy, powered by @chrysb/alphaclaw",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:stop": "docker compose down",
    "dev:clean": "docker compose down -v",
    "dev:logs": "docker compose logs -f",
    "dev:shell": "docker compose exec openclaw bash",
    "railway:oauth": "node scripts/railway-oauth.js",
    "railway:projects": "node scripts/railway-list-projects.js",
    "railway:logs": "node scripts/railway-logs.js",
    "railway:wait": "node scripts/railway-wait.js"
  },
  "dependencies": {
    "@chrysb/alphaclaw": "0.8.7",
    "openclaw": "2026.4.8"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
